{
  "schemaVersion": 1,
  "id": "levelz",
  "version": "${version}",
  "name": "LevelZ Refabricated",
  "description": "LevelZ ported and improved for Minecraft 1.21.11",
  "authors": [
    "Globox_Z",
    "Errnick_"
  ],
  "contact": {
    "sources": "https://github.com/errnicraft/LevelZ-Refabricated"
  },
  "license": "GPLv3",
  "icon": "assets/levelz/icon.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "dev.errnicraft.levelz_refabricated.LevelZRefabricated"
    ],
    "client": [
      "dev.errnicraft.levelz_refabricated.LevelZRefabricatedClient"
    ],
    "modmenu": [
      "dev.errnicraft.levelz_refabricated.config.ModMenuIntegration"
    ]
  },
  "mixins": [
    "levelz.mixins.json"
  ],
  "accessWidener": "levelz.accesswidener",
  "depends": {
    "java": ">=21",
    "minecraft": ">=${minecraft_version}",
    "fabric-api": ">=${fabric_version}",
    "fabricloader": ">=${loader_version}",
    "cloth-config2": ">=${cloth_config_version}",
    "libz": ">=1.0.0"
  },
  "custom": {
    "modmenu": {
      "parent": null
    }
  }
}
